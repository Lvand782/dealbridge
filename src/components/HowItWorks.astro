---
---

<section class="py-20 bg-white" id="how-it-works">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="inline-block text-orange-500 font-semibold text-sm uppercase tracking-wide mb-3">The Process</span>
      <h2 class="text-3xl md:text-4xl font-black text-navy mb-4">How DealBridge Works</h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        From first conversation to closing day — a streamlined process built around your timeline.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-10 left-1/3 right-1/3 h-0.5 bg-orange-200 -translate-y-1/2 z-0"></div>

      {[
        {
          step: "01",
          title: "List or Search",
          description: "Sellers submit a confidential profile for a free valuation. Buyers browse verified listings with financials and sign an NDA to unlock details.",
          icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        },
        {
          step: "02",
          title: "Connect & Negotiate",
          description: "Our deal room connects matched buyers and sellers. M&A advisors facilitate letters of intent, due diligence, and deal structure.",
          icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
        },
        {
          step: "03",
          title: "Close the Deal",
          description: "Finalize purchase agreements, coordinate with lenders (SBA or conventional), and execute a smooth transition. We're with you until keys are handed over.",
          icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
        }
      ].map((item) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="w-20 h-20 bg-navy rounded-full flex items-center justify-center mb-6 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
          </div>
          <span class="text-xs font-black text-orange-500 tracking-widest mb-2">{item.step}</span>
          <h3 class="text-xl font-black text-navy mb-3">{item.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed max-w-xs">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
