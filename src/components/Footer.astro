---
import { site } from "../data/site";
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-0 mb-4">
          <span class="text-2xl font-black text-white">Deal</span><span class="text-2xl font-black text-orange-400">Bridge</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          The trusted marketplace for buying and selling Main Street businesses.
        </p>
        <div class="flex gap-3">
          <a href={site.social.linkedin} class="w-8 h-8 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-colors" aria-label="LinkedIn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href={site.social.twitter} class="w-8 h-8 bg-white/10 hover:bg-white/20 rounded-lg flex items-center justify-center transition-colors" aria-label="Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- For Sellers -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-wide">For Sellers</h4>
        <ul class="space-y-2">
          {["Free Valuation", "How It Works", "Confidentiality", "Success Stories", "Seller FAQ"].map((item) => (
            <li>
              <a href="/sell" class="text-sm text-white/60 hover:text-white transition-colors">{item}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- For Buyers -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-wide">For Buyers</h4>
        <ul class="space-y-2">
          {["Browse Listings", "Premium Membership", "SBA Financing", "Due Diligence", "Buyer FAQ"].map((item) => (
            <li>
              <a href="/buy" class="text-sm text-white/60 hover:text-white transition-colors">{item}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-bold text-white mb-4 uppercase tracking-wide">Contact</h4>
        <ul class="space-y-3 text-sm text-white/60">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-orange-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
            </svg>
            <a href={`mailto:${site.email}`} class="hover:text-white transition-colors">{site.email}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-orange-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            <a href={`tel:${site.phone}`} class="hover:text-white transition-colors">{site.phone}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 text-orange-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
            </svg>
            <span>{site.address}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/40">
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-white transition-colors">NDA Template</a>
      </div>
      <p>© {new Date().getFullYear()} DealBridge. All rights reserved.</p>
      <p>
        Designed by <a
          href="https://www.outsourcemylife.us"
          target="_blank"
          rel="noopener noreferrer"
          class="text-orange-400 hover:text-orange-300 transition-colors font-medium"
          >Outsource My Life</a
        >
      </p>
    </div>
  </div>
</footer>
